    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "icons": {
    "library": "lucide"
  },
  "navigation": {
    "products": [
      {
        "product": "Overview",
        "description": "Overview, getting started, and product entry points",
        "icon": "book-open",
        "groups": [
          {
            "group": "Overview",
            "pages": ["index", "platform/overview"]
          },
          {
            "group": "Getting started",
            "pages": [
              "getting-started/what-is-alquimia",
              "getting-started/installation",
              "getting-started/first-login"
            ]
          },
          {
            "group": "Products",
            "pages": [
              "platform/runtime",
              "platform/studio",
              "platform/insight-hub"
            ]
          }
        ]
      },
      {
        "product": "Runtime",
        "description": "Core service of the Alquimia agent framework",
        "icon": "cpu",
        "href": "/platform/runtime"
      },
      {
        "$ref": "products/studio/navigation.json",
        "icon": "layout-dashboard"
      },
      {
        "$ref": "products/insight-hub/navigation.json",
        "icon": "brain"
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Alquimia",
        "href": "https://alquimia.ai"
      }
    ],
    "primary": {
