{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Alquimia Docs",
  "description": "Central documentation for the Alquimia ecosystem and its products.",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#5B21B6"
  },
  "favicon": "/favicon.ico",
