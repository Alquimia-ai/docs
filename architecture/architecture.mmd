flowchart TB
    subgraph External["External Sources"]
        CAM[Cameras]
    end

    subgraph Engine["Engine"]
        INGEST[Camera Connector]
        PIPELINE["AI Pipeline"]
        NORM[Event Normalizer]
        PUB[Publisher]
    end

    subgraph NATS["NATS (Message Broker)"]
        TOPIC[Events Subject]
    end

    subgraph BFF["Backend for Frontend"]
        AUTHM[Auth Middleware]
        REST[REST Controller]
        SSE[SSE Controller]
        SUB[Event Subscriber]
        EVTS[Event Service]
        CONFM[Configuration Manager]
    end

    CFDB[(Configuration DB)]
    EVDB[(Evidence DB)]

    subgraph Frontend["Web Client"]
        WEB[Web Dashboard]
    end

    %% Auth flow
    WEB -->|Bearer Token| AUTHM
    AUTHM --> REST
    AUTHM --> SSE

    %% Configuration flow
    Engine -->|"Startup: GET /api/cameras/engine"| REST
    REST --> CONFM
    CONFM --> CFDB
    CONFM -->|"Runtime: POST /config/cameras"| Engine

    %% Processing flow
    CAM -->|RTSP/HTTP Stream| INGEST
    INGEST -->|Frames| PIPELINE
    PIPELINE -->|Events| NORM
    NORM --> PUB

    %% Events flow
    PUB -->|Publish| TOPIC
    TOPIC -->|Subscribe| SUB
    SUB --> EVTS
    EVTS -->|Store evidence| EVDB
    SUB -->|Events| SSE
    SSE -->|Server-Sent Events| WEB
