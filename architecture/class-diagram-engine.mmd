classDiagram
    direction TB



    %% ── PreProcessing Package ──
    namespace PreProcessing {
        class FrameSource {
            <<abstract>>
            +stream() AsyncIterator~Frame~
            +start()
            +stop()
        }

        class Buffer~T~ {
            <<abstract>>
            +add(item: T)
            +get_batch() list~T~
            +flush() list~T~
            +is_ready() bool
            +__len__() int
        }

        class CameraProtocol {
            <<enum>>
            RTSP
            LOCAL
        }

        class ConnectionConfig {
            +stream_url: str
            +protocol: CameraProtocol
            +frame_interval: float
        }

        class FrameConfig {
            +target_width: int
            +target_height: int
            +jpeg_quality: int
        }

        class CameraModelConfig {
            +model: str
            +kwargs: dict
        }

        class ObservationConfig {
            +system_prompt: str
        }

        class DecisionConfig {
            +system_prompt: str
            +json_schema: dict
        }

        class CameraConfig {
            +id: str
            +name: str
            +enabled: bool
            +connection: ConnectionConfig
            +frame: FrameConfig
            +observation: ObservationConfig
            +decision: DecisionConfig
        }

        class FrameProcessor {
            +target_width: int
            +target_height: int
            +jpeg_quality: int
            +process(frame: ndarray) ndarray
            +encode(frame: ndarray) bytes
        }

        class CameraConnector {
            <<abstract>>
            +camera_id: str
            +stream_url: str
            +is_running: bool
            +start()
            +stop()
            +run_capture_loop()
            +stream() AsyncIterator~Frame~
        }

        class RtspCameraConnector {
            +start()
        }

        class LocalCameraConnector {
            +start()
        }

        class CameraConnectorFactory {
            -_registry: dict
            +register(protocol, cls)$
            +create(config: CameraConfig) CameraConnector
        }

        class PreprocessorManager {
            +start()
            +stop()
            +get_status() dict
            +add_camera(config: CameraConfig)
            +remove_camera(camera_id: str)
            +update_camera(config: CameraConfig)
        }

        class FrameBuffer {
            -max_size: int
            -batch_size: int
            -_frames: deque~Frame~
            -_lock: Lock
            -_policy: BufferFetchPolicy
            +add(item: Frame)
            +flush() list~Frame~
            +is_ready() bool
        }
    }

    %% ── Buffers Package ──
    namespace Buffers {
        class BufferFetchPolicy {
            <<protocol>>
            +fetch(items: deque, batch_size: int) list
        }
        class FIFOPolicy {
            +fetch(items: deque, batch_size: int) list
        }
    }

    %% ── Registry Package ──
    namespace Registry {
        class CameraBuffers {
            +frame_buffer: FrameBuffer
            +stories_buffer: StoriesBuffer
        }

        class EngineStateRegistry {
            <<singleton>>
            -_instance: EngineStateRegistry$
            -_cameras: dict~str, CameraConfig~
            -_buffers: dict~str, CameraBuffers~
            -_lock: Lock
            +get_instance() EngineStateRegistry$
            +get_cameras() list~CameraConfig~
            +get_camera(camera_id: str) CameraConfig
            +add_camera(config: CameraConfig)
            +update_camera(config: CameraConfig)
            +remove_camera(camera_id: str)
            +get_buffers(camera_id: str) CameraBuffers
        }
    }

    %% ── Processing Package ──
    namespace Processing {
        class VLMProcessor {
            -model: BaseChatModel
            -system_prompt: str
            +process(frames: list~Frame~) list~Description~
        }

        class Aggregator {
            +aggregate(descriptions: list~Description~, frames: list~Frame~) list~Story~
        }

        class StoriesBuffer {
            -max_size: int
            -batch_size: int
            -_stories: deque~Story~
            -_lock: Lock
            -_policy: BufferFetchPolicy
            +add(item: Story)
            +get_batch() list~Story~
            +flush() list~Story~
            +is_ready() bool
        }

        class LLMDetector {
            -model: BaseChatModel
            -system_prompt: str
            -_structured_model: BaseChatModel
            +detect(stories: list~Story~) Event?
        }

        class ValidationCommand {
            <<abstract>>
            +execute(event: Event) Event?
        }

        class ConfidenceThresholdCheck {
            -min_confidence: float
            +execute(event: Event) Event?
        }

        class SeverityNormalization {
            +execute(event: Event) Event?
        }

        class MetadataCleanup {
            +execute(event: Event) Event?
        }

        class FrameEncoding {
            +execute(event: Event) Event?
        }

        class EventNormalizer {
            -commands: list~ValidationCommand~
            +add_command(cmd: ValidationCommand)
            +normalize(event: Event) Event?
        }

        class ProcessingManager {
            -_registry: EngineStateRegistry
            -_aggregator: Aggregator
            -_normalizer: EventNormalizer
            -_vlm_cache: dict~str, VLMProcessor~
            -_llm_cache: dict~str, LLMDetector~
            -_camera_tasks: dict~str, tuple~Task,Task~~
            -_llm_events: dict~str, Event~
            -_running: bool
            +start()
            +stop()
            +add_camera(config: CameraConfig)
            +remove_camera(camera_id: str)*
            +update_camera(config: CameraConfig)*
            -_start_camera_tasks(camera_id: str)
            -_stop_camera_tasks(camera_id: str)*
            -_vlm_loop(camera_id: str)*
            -_llm_loop(camera_id: str)*
        }
    }

    %% ── PostProcessing Package ──
    namespace PostProcessing {
        class EventPublisher {
            <<abstract>>
            +publish(event: Event)
            +connect()
            +disconnect()
        }

        class EventSerializer {
            +serialize(event: Event) bytes
        }

        class NatsPublisher {
            -_serializer: EventSerializer
            -_client: NatsClient
            -_subject_prefix: str
            +connect()
            +disconnect()
            +publish(event: Event)
        }
    }

    %% ── Global Config ──
    namespace Config {
        class BFFSettings {
            +base_url: str
        }

        class BufferSettings {
            +frame_buffer_size: int
            +frame_batch_size: int
            +stories_buffer_size: int
            +stories_batch_size: int
        }

        class EngineSettings {
            +host: str
            +port: int
            +log_level: str
            +bff: BFFSettings
            +buffers: BufferSettings
        }
    }


    %% ── Relationships: PreProcessing ──
    FrameSource <|-- CameraConnector
    Buffer~T~ <|-- FrameBuffer
    Buffer~T~ <|-- StoriesBuffer
    CameraConnector <|-- RtspCameraConnector
    CameraConnector <|-- LocalCameraConnector
    CameraConnector --> FrameProcessor : uses
    CameraConnectorFactory --> CameraConnector : creates
    PreprocessorManager --> CameraConnectorFactory : uses
    CameraConfig --> ConnectionConfig
    CameraConfig --> FrameConfig
    CameraConfig --> ObservationConfig
    CameraConfig --> DecisionConfig
    ConnectionConfig --> CameraProtocol
    ObservationConfig --|> CameraModelConfig
    DecisionConfig --|> CameraModelConfig

    %% ── Relationships: Registry ──
    EngineStateRegistry *-- CameraBuffers : "per camera"
    CameraBuffers *-- FrameBuffer
    CameraBuffers *-- StoriesBuffer
    EngineStateRegistry --> CameraConfig : stores
    PreprocessorManager --> EngineStateRegistry : reads cameras
    ProcessingManager --> EngineStateRegistry : reads config + buffers

    %% ── Relationships: Processing data flow ──
    Aggregator ..> StoriesBuffer : "add()"
    StoriesBuffer ..> LLMDetector : "is_ready() → get_batch()"
    EventNormalizer *-- ValidationCommand : "runs sequentially"
    ValidationCommand <|-- ConfidenceThresholdCheck
    ValidationCommand <|-- SeverityNormalization
    ValidationCommand <|-- MetadataCleanup
    ValidationCommand <|-- FrameEncoding

    %% ── Relationships: Processing orchestrator ──
    ProcessingManager *-- Aggregator
    ProcessingManager *-- EventNormalizer
    ProcessingManager ..> VLMProcessor : "creates per camera"
    ProcessingManager ..> LLMDetector : "creates per camera"

    %% ── Relationships: PostProcessing ──
    EventPublisher <|-- NatsPublisher
    NatsPublisher --> EventSerializer : uses

    %% ── Relationships: Buffers ──
    BufferFetchPolicy <|-- FIFOPolicy
    FrameBuffer --> BufferFetchPolicy : uses
    StoriesBuffer --> BufferFetchPolicy : uses

    %% ── Relationships: Config ──
    EngineSettings --> BFFSettings
    EngineSettings --> BufferSettings
