flowchart LR
    subgraph Engine["Engine"]
        direction TB

        subgraph Ingestion["PreProcessor"]
            MGR[Preprocessor Manager]
            CF[Connector Factory]
            SP[Camera Connector]
            FE[Frame Processor]
        end

        subgraph StateRegistry["State Registry"]
            REG[Engine State Registry]
            BUFS["Per-Camera Buffers\n(FrameBuffer + StoriesBuffer)"]
        end

        subgraph Processing["Processing Manager"]
            VLM[VLM Processor]
            AGG[Aggregator]
            LLM[LLM Detector]
        end

        subgraph Normalizer["Event Normalizer"]
            VALID[Validation Pipeline]
        end

        subgraph PostProcessor["PostProcessor"]
            ES[Event Serializer]
            PUB[Publisher]
        end
    end

    BFF[BFF Service]

    %% Config flow
    BFF -->|"Startup: GET /api/cameras/engine"| REG
    BFF -->|"Runtime: POST /config/cameras"| REG
    REG -->|Camera configs| MGR

    %% Preprocessor flow
    MGR --> CF
    CF -->|Dispatches by protocol| SP
    SP --> FE

    %% Frames → Registry
    FE -->|Push frames| BUFS

    %% Processing flow
    BUFS -->|Frames batch| VLM
    VLM --> AGG
    AGG -->|Stories| BUFS
    BUFS -->|Stories batch| LLM
    LLM -->|Event| VALID

    %% Post-processing
    VALID --> ES
    ES --> PUB
